{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "pnpm --filter @folio/web build",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": "web/.next",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- web shared pnpm-lock.yaml package.json"
}
