# =============================================================================
# folio.e8e — environment variables
# Copy to .env.local and fill in values. Never commit .env.local.
# =============================================================================

# ---- Supabase ---------------------------------------------------------------
# Public (client-safe) — used by web and mobile
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Anthropic (Advisor agent, Haiku materiality scoring) -------------------
ANTHROPIC_API_KEY=sk-ant-...

# ---- AWS KMS (Alpaca key envelope encryption) -------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
KMS_KEY_ID=arn:aws:kms:us-east-1:...:key/...

# ---- Market data and news ---------------------------------------------------
FMP_API_KEY=
POLYGON_API_KEY=
BENZINGA_API_KEY=
# SEC EDGAR is keyless but requires a user-agent header
EDGAR_USER_AGENT=folio.e8e contact@e8e.com

# ---- Alpaca (BYOK — user keys are stored per-user, not here) ----------------
# These are kept only for local smoke tests against the paper sandbox.
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER_TEST_KEY=
ALPACA_PAPER_TEST_SECRET=

# ---- Observability ----------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_DSN=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ---- Cloudflare R2 (trace and prompt archival) ------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=folio-traces

# ---- Email (retrospective digests) ------------------------------------------
RESEND_API_KEY=

# ---- Feedback loop (Phase 2 learning — carried over from template) ---------
SLACK_WEBHOOK_URL=
SLACK_FEEDBACK_CHANNEL=e8e-folio-feedback
SLACK_DEV_CHANNEL=e8e-folio-dev
SLACK_FEEDBACK_CHANNEL_ID=
SLACK_DEV_CHANNEL_ID=

# ---- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
