# =============================================================================
# PROJECT ENVIRONMENT VARIABLES
# Copy to .env.local and fill in your values
# Generated by bootstrap.sh — DO NOT commit .env.local to git
# =============================================================================

# Supabase (set automatically by bootstrap.sh)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx
SLACK_FEEDBACK_CHANNEL=projectname-feedback
SLACK_DEV_CHANNEL=projectname-dev
SLACK_FEEDBACK_CHANNEL_ID=C0123456789
SLACK_DEV_CHANNEL_ID=C9876543210

# Project
PROJECT_NAME=your-project-name

# Claude Code Routines (set after creating routines at claude.ai/code/routines)
# These are only needed if you wire the smoke test to Vercel deploy hooks
SMOKE_TEST_ROUTINE_URL=https://api.anthropic.com/v1/claude_code/routines/trig_.../fire
SMOKE_TEST_ROUTINE_TOKEN=sk-ant-oat01-xxxxx
